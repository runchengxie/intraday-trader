# ── Alpaca ──────────────────────────────────────────────────
APCA_API_KEY_ID="replace-with-your-apca-api-key-id"
APCA_API_SECRET_KEY="replace-with-your-apca-api-secret-key"
ALPACA_BASE_URL="https://paper-api.alpaca.markets"

# ── 数据库（Docker live profile 需要） ──────────────────────
# POSTGRES_PASSWORD="your-password"

# ── 富途 FutuOpenD（可选，仅在 broker.name / provider.name 设为 futu 时需要） ──
# FUTU_HOST="127.0.0.1"
# FUTU_PORT="11111"
# FUTU_TRD_ENV="SIMULATE"       # SIMULATE 或 REAL
# FUTU_MARKET="HK"              # HK / US / CN
# FUTU_UNLOCK_PWD=""            # REAL 模式下必填，用于解锁交易
