+def _resolve_command(argv: Sequence[str]) -> tuple[str, list[str]]:
+    """Resolve the top-level command and preserve all child command options."""
+
+    if not argv:
+        raise CommandNotFoundError("missing command")
+
+    command = argv[0]
+
+    if command == "backtest":
+        if len(argv) < 2:
+            raise CommandNotFoundError(
+                f"missing backtest command. Available: {_available(_BACKTEST_COMMANDS)}"
+            )
+        subcommand = argv[1]
+        target = _BACKTEST_COMMANDS.get(subcommand)
+        if target is None:
+            raise CommandNotFoundError(
+                f"unknown backtest command '{subcommand}'. Available: {_available(_BACKTEST_COMMANDS)}"
+            )
+        return target, list(argv[2:])
+
+    if command == "data":
+        if len(argv) < 2:
+            raise CommandNotFoundError(
+                f"missing data command. Available: {_available(_DATA_COMMANDS)}"
+            )
